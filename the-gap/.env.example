# ── Frontend (Vercel) ─────────────────────────────────────────────────────
# URL of your Railway backend (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# Supabase project URL and anon key (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend (Railway) ─────────────────────────────────────────────────────
# Supabase project URL (same as above)
SUPABASE_URL=https://xxxx.supabase.co

# Supabase service role key (secret — never expose in browser)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Max upload size in MB (default 500)
MAX_UPLOAD_MB=500

# Environment tag
ENVIRONMENT=production
